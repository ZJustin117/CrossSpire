{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crossspire.dev/protocol-schema.json",
  "title": "CrossSpire Protocol",
  "description": "Message format definitions for CrossSpire multiplayer mod. Shared source of truth for Java and TypeScript implementations.",
  "definitions": {
    "GameMessage": {
      "type": "object",
      "required": ["type", "source", "seq"],
      "properties": {
        "type": { "type": "string", "description": "Message type discriminator" },
        "subtype": { "type": "string", "description": "Optional subtype for state_sync / stage_sync" },
        "source": { "type": "string", "description": "Sender player ID (UUID)" },
        "seq": { "type": "integer", "description": "Monotonic sequence number per source" },
        "target": { "type": "string", "description": "Target player ID; absent for broadcast" },
        "timestamp": { "type": "number", "description": "Send timestamp (epoch ms)" }
      }
    },
    "EffectDescription": {
      "type": "object",
      "required": ["kind", "target", "amount"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["damage", "gain_block", "apply_power", "remove_power", "heal", "gain_energy",
            "draw_card", "discard_card", "exhaust_card", "gain_gold", "obtain_relic",
            "obtain_potion", "lose_hp", "magic_number", "set_monster_hp", "monster_death",
            "obtain_card", "remove_card", "remove_relic", "remove_potion", "max_hp", "deck_size"],
          "description": "set_monster_hp / monster_death are planned monster-authority effects; obtain/remove_* cover personal event inventory deltas"
        },
        "target": { "type": "string" },
        "amount": { "type": "integer" },
        "card_id": { "type": "string" },
        "relic_id": { "type": "string" },
        "potion_id": { "type": "string" },
        "power_id": { "type": "string" },
        "damage_type": { "type": "string" },
        "logic_owner_id": {
          "type": "string",
          "description": "Logic owner of a buff/power (applier-first). Required for apply_power semantics."
        },
        "origin_owner_id": {
          "type": "string",
          "description": "Owner that produced this effect during local-owner-only induced replay"
        },
        "hop_count": {
          "type": "integer",
          "description": "Induced side-effect hop count; drop when exceeding policy limit"
        }
      }
    },
    "OperationStep": {
      "type": "object",
      "properties": {
        "step": { "type": "string" },
        "card_id": { "type": "string" },
        "source": { "type": "string" },
        "target": { "type": "string" },
        "amount": { "type": "integer" },
        "vfx_kind": { "type": "string" },
        "logic_owner_id": { "type": "string" },
        "power_id": { "type": "string" }
      }
    },
    "ComponentAttachment": {
      "type": "object",
      "description": "Buff/power instance attached to a host entity. Logic owner = applier-first.",
      "properties": {
        "instance_id": { "type": "string" },
        "resource_id": { "type": "string" },
        "resource_hash": { "type": "string" },
        "logic_owner_id": { "type": "string", "description": "Applier-first logic owner" },
        "host_entity_id": { "type": "string", "description": "player:<id> | monster:<instance_id>" },
        "amount": { "type": "integer" },
        "power_id": { "type": "string" }
      }
    },
    "MonsterMutationProposal": {
      "type": "object",
      "description": "Planned: non-stage-host proposes monster state change; stage host is sole writer.",
      "properties": {
        "transaction_id": { "type": "string" },
        "cause_packet_id": { "type": "string" },
        "monster_instance_id": { "type": "string" },
        "base_revision": { "type": "integer" },
        "logic_owner_id": { "type": "string" },
        "effects": { "type": "array", "items": { "$ref": "#/definitions/EffectDescription" } },
        "operation_sequence": { "type": "array", "items": { "$ref": "#/definitions/OperationStep" } }
      }
    },
    "MonsterMutationCommit": {
      "type": "object",
      "description": "Planned: stage host authoritative monster state commit after proposal.",
      "properties": {
        "transaction_id": { "type": "string" },
        "monster_instance_id": { "type": "string" },
        "commit_revision": { "type": "integer" },
        "status": { "type": "string", "enum": ["accepted", "rejected", "stale", "duplicate"] },
        "reason": { "type": "string" },
        "effects": { "type": "array", "items": { "$ref": "#/definitions/EffectDescription" } },
        "hp": { "type": "integer" },
        "max_hp": { "type": "integer" },
        "block": { "type": "integer" },
        "dead": { "type": "boolean" },
        "escaped": { "type": "boolean" },
        "half_dead": { "type": "boolean" }
      }
    },
    "MemberInfo": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ip": { "type": "string" },
        "port": { "type": "integer" }
      }
    },
    "RemotePlayerState": {
      "type": "object",
      "properties": {
        "hp": { "type": "integer" },
        "max_hp": { "type": "integer" },
        "block": { "type": "integer" },
        "energy": { "type": "integer" },
        "gold": { "type": "integer" },
        "character_class": { "type": "string" },
        "powers": { "type": "array", "items": { "type": "string" } },
        "power_amounts": { "type": "array", "items": { "type": "integer" } },
        "relics": { "type": "array", "items": { "type": "string" } },
        "potions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "PartyInfo": {
      "type": "object",
      "required": ["party_id", "leader_id", "member_ids", "phase_status", "act_id", "party_revision"],
      "properties": {
        "party_id": { "type": "string" },
        "leader_id": { "type": "string" },
        "member_ids": { "type": "array", "items": { "type": "string" } },
        "phase_status": { "type": "string", "enum": ["stage_transition", "map_active", "active_node", "map_completed"] },
        "act_id": { "type": "string" },
        "map_instance_id": { "type": "string" },
        "map_position": { "type": "string", "description": "Stable current node_id; absent before a map is bound" },
        "node_instance_host_id": { "type": "string" },
        "active_node_instance_id": { "type": "string" },
        "party_revision": { "type": "integer" }
      }
    },
    "MapDefinition": {
      "type": "object",
      "description": "Immutable map topology. It never contains generated node content.",
      "required": ["map_instance_id", "act_id", "map_revision", "start_node_id", "nodes"],
      "properties": {
        "map_instance_id": { "type": "string" },
        "act_id": { "type": "string" },
        "map_revision": { "type": "integer" },
        "generation_digest": { "type": "string" },
        "start_node_id": { "type": "string", "description": "Stable entry node for a party newly bound to this map" },
        "boss_descriptor": { "type": "object" },
        "nodes": { "type": "array", "items": { "$ref": "#/definitions/MapNode" } }
      }
    },
    "MapNode": {
      "type": "object",
      "description": "Immutable topology node. Node content is resolved only by NodeInstanceHost after allocation.",
      "required": ["node_id", "outgoing_node_ids"],
      "properties": {
        "node_id": { "type": "string" },
        "x": { "type": "integer" },
        "y": { "type": "integer" },
        "room_type": { "type": "string" },
        "icon": { "type": "string" },
        "burning_elite": { "type": "boolean" },
        "outgoing_node_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "NodeInstanceInfo": {
      "type": "object",
      "required": ["node_instance_id", "map_instance_id", "party_id", "node_id", "visit_id", "node_instance_host_id", "status"],
      "properties": {
        "node_instance_id": { "type": "string" },
        "map_instance_id": { "type": "string" },
        "party_id": { "type": "string" },
        "node_id": { "type": "string" },
        "room_type": { "type": "string", "description": "Immutable map node category supplied with allocation." },
        "visit_id": { "type": "integer" },
        "node_instance_host_id": { "type": "string" },
        "status": { "type": "string", "enum": ["allocated", "generating", "active", "cleared", "abandoned"] },
        "generation_revision": { "type": "integer" },
        "state_revision": { "type": "integer" }
      }
    },
    "NodeGenerationResult": {
      "type": "object",
      "description": "NodeInstanceHost's resolved content for one allocated node. Room-type-specific descriptors are required for combat and event nodes.",
      "required": ["room_type", "node_id"],
      "properties": {
        "room_type": {
          "type": "string",
          "enum": ["monster", "event", "elite", "shop", "rest", "treasure", "boss"],
          "description": "Resolved node category. Immutable map '?' nodes resolve here before open."
        },
        "encounter": {
          "type": "string",
          "description": "Required when room_type is monster, elite, or boss."
        },
        "node_id": { "type": "string" },
        "event_interface": {
          "type": "object",
          "description": "Required when room_type is event; NodeInstanceHost publishes it after node_instance_opened.",
          "properties": {
            "event_instance_id": { "type": "string" },
            "party_id": { "type": "string" },
            "event_class": { "type": "string" },
            "event_id": { "type": "string" },
            "resource_hash": { "type": "string" },
            "name": { "type": "string" },
            "description": { "type": "string" },
            "mode": { "type": "string", "enum": ["individual", "voting"] },
            "options": { "type": "array" }
          }
        },
        "shop_seed": {
          "type": "string",
          "description": "Optional local-only shop seed hint. Not multiplayer inventory SoT; shop rooms sync type/instance only."
        },
        "rest_options": {
          "type": "array",
          "description": "Optional local-only rest option hint. Not multiplayer SoT; rest rooms sync type/instance only."
        },
        "treasure_tier": {
          "type": "string",
          "description": "Optional local-only treasure tier hint. Not multiplayer loot SoT."
        }
      }
    }
  },
  "messageTypes": {
    "connected": {
      "description": "Server → Client: handshake with assigned playerId",
      "extends": "GameMessage",
      "properties": { "playerId": { "type": "string" } }
    },
    "join": {
      "description": "Client → Server: request to join a room",
      "properties": { "code": { "type": "string" } }
    },
    "room_state": {
      "description": "Server → Client: current room state on join",
      "extends": "GameMessage",
      "properties": {
        "code": { "type": "string" },
        "host": { "type": "string", "description": "Room host player ID (first to join)" },
        "players": { "type": "array", "items": { "type": "string" } }
      }
    },
    "player_joined": {
      "description": "Server → Broadcast: new player entered room",
      "extends": "GameMessage",
      "properties": { "playerId": { "type": "string" } }
    },
    "player_left": {
      "description": "Server → Broadcast: player left room",
      "extends": "GameMessage",
      "properties": { "playerId": { "type": "string" } }
    },
    "ping": {
      "description": "Client ↔ Server: keepalive"
    },
    "pong": {
      "description": "Client ↔ Server: keepalive response"
    },
    "hello": {
      "description": "Peer → Broadcast: announce P2P network info",
      "extends": "GameMessage",
      "properties": {
        "ip": { "type": "string" },
        "port": { "type": "integer" },
        "peers": { "type": "array", "items": { "$ref": "#/definitions/MemberInfo" } }
      }
    },
    "player_ready": {
      "description": "Client → Broadcast: lobby ready with character choice",
      "extends": "GameMessage",
      "properties": { "character": { "type": "string" } }
    },
    "queue_packet": {
      "description": "Player → Broadcast: submit card to distributed queue",
      "extends": "GameMessage",
      "properties": {
        "packet_id": { "type": "string" },
        "sender_id": { "type": "string" },
        "owner_id": { "type": "string" },
        "timestamp": { "type": "number" },
        "card_id": { "type": "string" },
        "resource_hash": { "type": "string" },
        "target": { "type": "string" }
      }
    },
    "queue_complete": {
      "description": "Owner → Broadcast: card execution finished",
      "extends": "GameMessage",
      "properties": {
        "packet_id": { "type": "string" },
        "card_id": { "type": "string" },
        "effects": { "type": "array", "items": { "$ref": "#/definitions/EffectDescription" } },
        "operation_sequence": { "type": "array", "items": { "$ref": "#/definitions/OperationStep" } }
      }
    },
    "invoke": {
      "description": "Peer → Target: dereference a remote reference",
      "extends": "GameMessage",
      "properties": {
        "ref_id": { "type": "string" },
        "trigger": { "type": "string" },
        "args": { "type": "string" }
      }
    },
    "invoke_result": {
      "description": "Target → Peer: result of remote dereference",
      "extends": "GameMessage",
      "properties": {
        "ref_id": { "type": "string" },
        "effects": { "type": "array", "items": { "$ref": "#/definitions/EffectDescription" } },
        "operation_sequence": { "type": "array", "items": { "$ref": "#/definitions/OperationStep" } }
      }
    },
    "player_state": {
      "description": "Peer → Broadcast: remote player HP/block/energy update",
      "extends": "GameMessage",
      "properties": { "player": { "$ref": "#/definitions/RemotePlayerState" } }
    },
    "stage_sync": {
      "description": "Deprecated legacy StageHost synchronization. New map and node contracts are map_* and node_instance_* messages.",
      "extends": "GameMessage",
      "properties": {
        "character": { "type": "string" },
        "seed": { "type": "string" },
        "act": { "type": "integer" },
        "monster_ids": { "type": "array", "items": { "type": "string" } },
        "monster_hps": { "type": "array", "items": { "type": "integer" } }
      }
    },
    "monster_intent": {
      "description": "NodeInstanceHost → party: monster intent change for the active node instance",
      "extends": "GameMessage",
      "properties": {
        "monster_id": { "type": "string" },
        "intent": { "type": "string" },
        "damage": { "type": "integer" },
        "hits": { "type": "integer" },
        "target_id": { "type": "string" }
      }
    },
    "combat_result": {
      "description": "Party coordinator/NodeInstanceHost → party: authoritative card or monster execution result. Receivers apply effects under suppression; induced passive fire is local-owner-only (logic_owner_id == self), not full hook replay. monster_id=monster_turn carries turn_transaction_id to bind a NodeInstanceHost completion result to one combat_phase transaction.",
      "extends": "GameMessage",
      "properties": {
        "monster_id": { "type": "string" },
        "turn_transaction_id": { "type": "string", "description": "Required for monster_id=monster_turn; matches the active monster_turn combat_phase transaction" },
        "card_id": { "type": "string" },
        "executor_id": { "type": "string", "description": "Original REAL executor; must not be rewritten to room host" },
        "effects": { "type": "array", "items": { "$ref": "#/definitions/EffectDescription" } },
        "operation_sequence": { "type": "array", "items": { "$ref": "#/definitions/OperationStep" } }
      }
    },
    "combat_phase": {
      "description": "Room host → All authoritative combat phase alignment (T5.4). Clients advance local STS phase gates; buffs fire spontaneously only for local logic owners. Emitted on queue non-empty (resolving_queue), queue drain (queue_empty), and end-turn consensus (pre_monster_turn).",
      "extends": "GameMessage",
      "properties": {
        "phase": {
          "type": "string",
          "enum": ["player_turn", "resolving_queue", "queue_empty", "pre_monster_turn", "monster_turn", "post_monster_turn"]
        },
        "party_id": { "type": "string", "description": "Gameplay party; absent legacy packets default to P0" },
        "transaction_id": { "type": "string" }
      }
    },
    "party_snapshot": {
      "description": "RoomHost → peers: authoritative party directory snapshot",
      "properties": {
        "parties": { "type": "array", "items": { "$ref": "#/definitions/PartyInfo" } }
      }
    },
    "party_run_start_request": {
      "description": "Member → RoomHost: request coordinated run start after all party members ready (T7.7a)",
      "extends": "GameMessage",
      "properties": {
        "party_id": { "type": "string" },
        "seed": { "type": "string", "description": "Optional seed suggestion; RoomHost may ignore if already chosen" },
        "character": { "type": "string", "description": "Requester character override for ready table" }
      }
    },
    "party_run_start": {
      "description": "RoomHost/party leader → party: coordinated dual-client run start. Each member starts local GameStarter with own character and shared seed. Not host-spawn combat projection.",
      "extends": "GameMessage",
      "required": ["party_id", "seed", "act", "members", "leader_id"],
      "properties": {
        "party_id": { "type": "string" },
        "seed": { "type": "string" },
        "act": { "type": "integer" },
        "leader_id": { "type": "string" },
        "members": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["player_id", "character"],
            "properties": {
              "player_id": { "type": "string" },
              "character": { "type": "string" }
            }
          }
        }
      }
    },
    "reward_phase_enter": {
      "description": "NIH/leader → party: enter combat reward phase after victory (T7.8)",
      "extends": "GameMessage",
      "properties": {
        "party_id": { "type": "string" },
        "node_instance_id": { "type": "string" },
        "transaction_id": { "type": "string" }
      }
    },
    "reward_offer": {
      "description": "NIH → party: shared reward candidate pool (deterministic from node_instance_id); personal gold is not shared",
      "extends": "GameMessage",
      "properties": {
        "party_id": { "type": "string" },
        "node_instance_id": { "type": "string" },
        "card_ids": { "type": "array", "items": { "type": "string" } },
        "relic_ids": { "type": "array", "items": { "type": "string" } },
        "potion_ids": { "type": "array", "items": { "type": "string" } },
        "gold_min": { "type": "integer" },
        "gold_max": { "type": "integer" }
      }
    },
    "reward_pick": {
      "description": "Member → leader/NIH: personal reward selection (does not alter other players' gold/deck)",
      "extends": "GameMessage",
      "properties": {
        "party_id": { "type": "string" },
        "node_instance_id": { "type": "string" },
        "card_id": { "type": "string" },
        "relic_id": { "type": "string" },
        "potion_id": { "type": "string" },
        "skipped": { "type": "boolean" }
      }
    },
    "reward_player_result": {
      "description": "Member → party: personal reward apply delta (gold/deck/relics are personal economy)",
      "extends": "GameMessage",
      "properties": {
        "party_id": { "type": "string" },
        "node_instance_id": { "type": "string" },
        "player_id": { "type": "string" },
        "effects": { "type": "array", "items": { "$ref": "#/definitions/EffectDescription" } }
      }
    },
    "reward_done": {
      "description": "Member → leader: local CombatRewardScreen finished/Proceed",
      "extends": "GameMessage",
      "properties": {
        "party_id": { "type": "string" },
        "node_instance_id": { "type": "string" }
      }
    },
    "reward_phase_complete": {
      "description": "Leader → party: all members reward_done. Should unlock map navigation (same as room_exit_unlocked) for this room_instance.",
      "extends": "GameMessage",
      "properties": {
        "party_id": { "type": "string" },
        "node_instance_id": { "type": "string" }
      }
    },
    "room_exit_unlocked": {
      "description": "RoomInstanceHost/NodeInstanceHost → party: map navigation unlocked for this room instance. Members enable continue arrow / room_pin. Shop inventory and rest options are NOT synced—only room type was shared at open.",
      "extends": "GameMessage",
      "properties": {
        "party_id": { "type": "string" },
        "room_instance_id": { "type": "string", "description": "Same as node_instance_id for this visit" },
        "node_instance_id": { "type": "string" },
        "reason": { "type": "string", "description": "Optional: reward_complete | shop_leave | rest_leave | manual" }
      }
    },
    "room_exit_locked": {
      "description": "Optional: re-lock navigation while still in the same room instance (rare).",
      "extends": "GameMessage",
      "properties": {
        "party_id": { "type": "string" },
        "room_instance_id": { "type": "string" },
        "node_instance_id": { "type": "string" }
      }
    },
    "party_leave_request": {
      "description": "Member → RoomHost: leave current party into a single-member party",
      "properties": { "party_id": { "type": "string" } }
    },
    "party_join_request": {
      "description": "Member → RoomHost → party leader: request to join a party",
      "properties": {
        "party_id": { "type": "string" },
        "request_id": { "type": "string" }
      }
    },
    "party_join_approved": {
      "description": "Party leader → RoomHost: accept a pending join request",
      "properties": {
        "party_id": { "type": "string" },
        "request_id": { "type": "string" },
        "player_id": { "type": "string" }
      }
    },
    "party_join_rejected": {
      "description": "Party leader → RoomHost: reject a pending join request",
      "properties": {
        "party_id": { "type": "string" },
        "request_id": { "type": "string" },
        "player_id": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "party_leader_changed": {
      "description": "RoomHost → peers: deterministic party leader changed",
      "properties": {
        "party_id": { "type": "string" },
        "leader_id": { "type": "string" }
      }
    },
    "stage_transition_open": {
      "description": "RoomHost → party: opens a party-scoped transition outside any map or node instance.",
      "properties": {
        "party_id": { "type": "string" },
        "act_id": { "type": "string" },
        "party_revision": { "type": "integer" }
      }
    },
    "map_host_vote": {
      "description": "Party member → RoomHost: nominate a MapHost when creating a new map.",
      "properties": {
        "party_id": { "type": "string" },
        "candidate_id": { "type": "string" },
        "party_revision": { "type": "integer" }
      }
    },
    "map_host_result": {
      "description": "RoomHost → party: unanimous MapHost result for a new MapInstance.",
      "properties": {
        "party_id": { "type": "string" },
        "map_host_id": { "type": "string" },
        "party_revision": { "type": "integer" }
      }
    },
    "map_register": {
      "description": "MapHost → RoomHost: register one immutable MapDefinition. The MapHost has no node-content duties after acceptance.",
      "properties": {
        "party_id": { "type": "string" },
        "map_host_id": { "type": "string" },
        "request_id": { "type": "string" },
        "map": { "$ref": "#/definitions/MapDefinition" }
      }
    },
    "map_registered": {
      "description": "RoomHost → party: accepted immutable map registration, initial party binding, and the authoritative topology clients must reconstruct locally.",
      "properties": {
        "party_id": { "type": "string" },
        "map_instance_id": { "type": "string" },
        "start_node_id": { "type": "string" },
        "map_revision": { "type": "integer" },
        "party_revision": { "type": "integer" },
        "map": { "$ref": "#/definitions/MapDefinition" }
      }
    },
    "map_join_request": {
      "description": "Party → RoomHost: bind the party to an already registered map of the requested act.",
      "properties": {
        "party_id": { "type": "string" },
        "map_instance_id": { "type": "string" },
        "request_id": { "type": "string" },
        "party_revision": { "type": "integer" }
      }
    },
    "map_joined": {
      "description": "RoomHost → party: accepted map binding; the party must still select its own NodeInstanceHost.",
      "properties": {
        "party_id": { "type": "string" },
        "map": { "$ref": "#/definitions/MapDefinition" },
        "start_node_id": { "type": "string" },
        "party_revision": { "type": "integer" }
      }
    },
    "node_instance_host_vote": {
      "description": "Party member → RoomHost: nominate the party's single NodeInstanceHost.",
      "properties": {
        "party_id": { "type": "string" },
        "candidate_id": { "type": "string" },
        "party_revision": { "type": "integer" }
      }
    },
    "node_instance_host_result": {
      "description": "RoomHost → party: unanimous NodeInstanceHost result.",
      "properties": {
        "party_id": { "type": "string" },
        "node_instance_host_id": { "type": "string" },
        "party_revision": { "type": "integer" }
      }
    },
    "stage_transition_complete": {
      "description": "RoomHost → party: map binding and NodeInstanceHost are confirmed; party may enter MAP_ACTIVE.",
      "properties": {
        "party_id": { "type": "string" },
        "map_instance_id": { "type": "string" },
        "node_instance_host_id": { "type": "string" },
        "start_node_id": { "type": "string" },
        "party_revision": { "type": "integer" }
      }
    },
    "node_instance_allocate": {
      "description": "RoomHost → NodeInstanceHost: allocate or return an idempotent node instance after path validation.",
      "properties": {
        "node_instance": { "$ref": "#/definitions/NodeInstanceInfo" },
        "request_id": { "type": "string" }
      }
    },
    "node_generation_commit": {
      "description": "NodeInstanceHost → RoomHost: atomically commit generated node content metadata and room-generation modifier state deltas.",
      "properties": {
        "node_instance_id": { "type": "string" },
        "generation_revision": { "type": "integer" },
        "generation_result": { "$ref": "#/definitions/NodeGenerationResult" },
        "modifier_state_delta": { "type": "object" }
      }
    },
    "node_instance_opened": {
      "description": "RoomHost → party: node generation is committed and the party may enter the instance.",
      "properties": {
        "node_instance": { "$ref": "#/definitions/NodeInstanceInfo" },
        "generation_result": { "$ref": "#/definitions/NodeGenerationResult" }
      }
    },
    "monster_mutation_proposal": {
      "description": "Planned: Peer → current NodeInstanceHost (via RoomHost): propose monster core-state change from local-owner buff/card logic.",
      "extends": "GameMessage",
      "properties": {
        "proposal": { "$ref": "#/definitions/MonsterMutationProposal" }
      }
    },
    "monster_mutation_commit": {
      "description": "Planned: NodeInstanceHost → party (via RoomHost): authoritative monster state after proposal apply/reject.",
      "extends": "GameMessage",
      "properties": {
        "commit": { "$ref": "#/definitions/MonsterMutationCommit" }
      }
    },
    "monster_mutation_reject": {
      "description": "Planned: StageHost → Proposer: proposal rejected (stale revision / invalid).",
      "extends": "GameMessage",
      "properties": {
        "transaction_id": { "type": "string" },
        "monster_instance_id": { "type": "string" },
        "reason": { "type": "string" },
        "commit_revision": { "type": "integer" }
      }
    },
    "event_result": {
      "description": "StageHost → Broadcast: event outcome",
      "extends": "GameMessage",
      "properties": {
        "event_id": { "type": "string" },
        "effects": { "type": "array", "items": { "$ref": "#/definitions/EffectDescription" } }
      }
    },
    "event_interface": {
      "description": "NodeInstanceHost → RoomHost → party: open a party-scoped event instance with class/hash for native or fallback UI.",
      "properties": {
        "event_instance_id": { "type": "string" },
        "party_id": { "type": "string" },
        "event_class": { "type": "string" },
        "event_id": { "type": "string" },
        "resource_hash": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "mode": { "type": "string", "enum": ["individual", "voting"] },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "index": { "type": "integer" },
              "text": { "type": "string" },
              "enabled": { "type": "boolean" }
            }
          }
        }
      }
    },
    "event_choice_request": {
      "description": "Chooser → RoomHost: request approval before local buttonEffect side effects.",
      "properties": {
        "event_instance_id": { "type": "string" },
        "party_id": { "type": "string" },
        "request_id": { "type": "string" },
        "ui_step": { "type": "string" },
        "option_index": { "type": "integer" },
        "selected_cards": { "type": "array", "items": { "type": "string" } },
        "selected_targets": { "type": "array", "items": { "type": "string" } },
        "resource_hash": { "type": "string" }
      }
    },
    "event_choice_approved": {
      "description": "RoomHost → chooser (or party for voting): approved request may continue local execution.",
      "properties": {
        "event_instance_id": { "type": "string" },
        "party_id": { "type": "string" },
        "request_id": { "type": "string" },
        "ui_step": { "type": "string" },
        "option_index": { "type": "integer" }
      }
    },
    "event_choice_rejected": {
      "description": "RoomHost → chooser: request rejected (bad member/option/step/hash/duplicate).",
      "properties": {
        "event_instance_id": { "type": "string" },
        "party_id": { "type": "string" },
        "request_id": { "type": "string" },
        "ui_step": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "event_player_result": {
      "description": "Chooser/NIH → RoomHost → party: personal outcome after an approved choice.",
      "properties": {
        "event_instance_id": { "type": "string" },
        "party_id": { "type": "string" },
        "request_id": { "type": "string" },
        "player_id": { "type": "string" },
        "effects": { "type": "array", "items": { "$ref": "#/definitions/EffectDescription" } },
        "shared_outcome": {
          "type": "object",
          "description": "Optional party-scoped shared consequence (event-room path or leave_party). event_room opens a shared STS combat shell for listed members (T7.5).",
          "properties": {
            "type": { "type": "string", "enum": ["event_room", "leave_party"] },
            "instance_id": { "type": "string" },
            "option_index": { "type": "integer" },
            "encounter": {
              "type": "string",
              "description": "When type=event_room: MonsterHelper encounter key for the shared fight shell"
            },
            "member_ids": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Players on this event-room path; only they force-enter the combat shell"
            }
          }
        }
      }
    },

    "reference_register": {
      "description": "Peer → Broadcast: announce available references",
      "extends": "GameMessage",
      "properties": {
        "ref_id": { "type": "string" },
        "resource_type": { "type": "string" },
        "resource_id": { "type": "string" },
        "resource_hash": { "type": "string" }
      }
    },
    "reference_migrate": {
      "description": "Peer → Broadcast: request reference migration to new owner",
      "extends": "GameMessage",
      "properties": {
        "ref_id": { "type": "string" },
        "resource_type": { "type": "string" },
        "resource_id": { "type": "string" },
        "resource_hash": { "type": "string" }
      }
    },
    "resource_registry": {
      "description": "Peer → Broadcast: local mod content manifest",
      "extends": "GameMessage",
      "properties": {
        "cards": { "type": "array", "items": { "type": "string" } },
        "relics": { "type": "array", "items": { "type": "string" } },
        "powers": { "type": "array", "items": { "type": "string" } },
        "potions": { "type": "array", "items": { "type": "string" } },
        "characters": { "type": "array", "items": { "type": "string" } }
      }
    },
    "resource_request": {
      "description": "Client → Target: request asset bytes",
      "extends": "GameMessage",
      "properties": {
        "resource_type": { "type": "string" },
        "resource_id": { "type": "string" }
      }
    },
    "resource_response": {
      "description": "Target → Client: asset data",
      "extends": "GameMessage",
      "properties": {
        "resource_type": { "type": "string" },
        "resource_id": { "type": "string" },
        "checksum": { "type": "string" }
      }
    },
    "stage_host_election": {
      "description": "Deprecated legacy room-wide StageHost election. Use party-scoped map_host_vote instead.",
      "extends": "GameMessage",
      "properties": {
        "candidates": { "type": "array", "items": { "type": "string" } }
      }
    },
    "stage_host_result": {
      "description": "Deprecated legacy room-wide StageHost result. Use map_host_result instead.",
      "extends": "GameMessage",
      "properties": {
        "host_id": { "type": "string" }
      }
    },
    "full_snapshot": {
      "description": "RoomHost/directory snapshot: parties, maps, attachments, active nodes, plus local player combat fields when available.",
      "extends": "GameMessage",
      "properties": {
        "parties": { "type": "array" },
        "maps": { "type": "array", "items": { "$ref": "#/definitions/MapDefinition" } },
        "attachments": { "type": "array" },
        "active_node_instances": { "type": "array" },
        "stage": { "type": "object" },
        "player": { "type": "object" },
        "monsters": { "type": "array" },
        "stage_sync": { "$ref": "#/messageTypes/stage_sync" },
        "players": { "type": "array", "items": { "$ref": "#/definitions/RemotePlayerState" } },
        "pending_messages": { "type": "array" }
      }
    },
    "animation_sync": {
      "description": "Player → Broadcast: character animation state",
      "extends": "GameMessage",
      "properties": {
        "player_id": { "type": "string" },
        "animation_name": { "type": "string" }
      }
    },
    "player_end_turn": {
      "description": "Player → Room host: end turn signal. Room host aggregates alignment; does not mean stage host triggers remote buffs.",
      "extends": "GameMessage"
    },
    "queue_submit": {
      "description": "Client → Host: submit card to central queue (target=hostId for routing, game_target=in-game target)",
      "extends": "GameMessage",
      "properties": {
        "sender_id": { "type": "string" },
        "owner_id": { "type": "string" },
        "card_id": { "type": "string" },
        "resource_hash": { "type": "string" },
        "game_target": { "type": "string", "description": "In-game target: monster_0 | player_b | self" },
        "timestamp": { "type": "number" }
      }
    },
    "queue_update": {
      "description": "Host → All: current queue state snapshot",
      "extends": "GameMessage",
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "packet_id": { "type": "string" },
              "sender_id": { "type": "string" },
              "owner_id": { "type": "string" },
              "card_id": { "type": "string" },
              "target": { "type": "string" },
              "status": { "type": "string", "enum": ["pending", "executing", "done"] }
            }
          }
        }
      }
    },
    "queue_empty": {
      "description": "Room host → All: queue drained, end turn allowed. Also a combat-phase alignment signal for local owner-only buff timing.",
      "extends": "GameMessage"
    }
  }
}
