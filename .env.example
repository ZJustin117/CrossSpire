# CrossSpire local machine config (copy to .env.local and fill).
# Never commit .env.local. Shared docs and agents only reference these names.

# --- Required for JUnit / jar builds ---
# SlayTheAmethyst checkout root (or equivalent assets root)
SLAY_THE_AMETHYST_ROOT=
# Absolute path to STS desktop-1.0.jar
CROSSSPIRE_STS_JAR=
# Optional overrides; if empty, agents/docs derive from SLAY_THE_AMETHYST_ROOT
# CROSSSPIRE_BASEMOD_JAR=$SLAY_THE_AMETHYST_ROOT/app/src/main/assets/components/mods/BaseMod.jar
# CROSSSPIRE_MODTHESPIRE_JAR=$SLAY_THE_AMETHYST_ROOT/app/src/main/assets/components/mods/ModTheSpire.jar
CROSSSPIRE_BASEMOD_JAR=
CROSSSPIRE_MODTHESPIRE_JAR=

# --- Required for Android harness / connector ---
# Connector daemon listen port on the developer machine
STS_CONNECTOR_PORT=
# ADB serials as seen by the developer machine (D1 = room host, D2 = join client)
CROSSSPIRE_D1_SERIAL=
CROSSSPIRE_D2_SERIAL=
# In-game P2P port used by crossspire host/join
CROSSSPIRE_GAME_PORT=54321

# --- Optional ---
# Default Arthas/device target when only one device is needed
STS_TEST_DEVICE=
# Device-side ports (defaults match Amethyst harness)
CROSSSPIRE_GAME_PROBE_PORT=9099
CROSSSPIRE_ARTHAS_PORT=8099
